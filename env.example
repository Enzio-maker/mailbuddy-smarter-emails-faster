# MailBuddy – Environment Variables
# Kopieer dit bestand naar .env en vul de waarden in

# === BACKEND (server.js) ===
ANTHROPIC_API_KEY=sk-ant-...          # https://console.anthropic.com/keys
PORT=3001                              # Poort voor de Express backend
FRONTEND_URL=http://localhost:5173     # URL van de Vite dev server (CORS)

# === FRONTEND (Vite) ===
# Vite variabelen MOETEN beginnen met VITE_
VITE_API_URL=http://localhost:3001     # Verwijst naar de backend (lokaal)
# Op productie: https://jouw-backend.vercel.app

# === SUPABASE (al aanwezig) ===
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
